# Configuración de la base de datos
DATABASE_URL="postgresql://user:pass@host:5432/db?schema=public"

# Configuración de JWT
JWT_ACCESS_SECRET="your_jwt_access_secret_key_here"
JWT_REFRESH_SECRET="your_jwt_refresh_secret_key_here"
JWT_ACCESS_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# Configuración del servidor
PORT=4001
NODE_ENV="development"

# Configuración de CORS
CORS_ORIGIN="http://localhost:3000"

# Configuración de logs
LOG_LEVEL="debug"

# Configuración de seguridad
RATE_LIMIT=100
RATE_LIMIT_WINDOW_MS=900000  # 15 minutos

# Configuración de SMTP para envío de correos
HOST_EMAIL="smtp.gmail.com"
PORT_EMAIL="587"
SMTP_SECURE="false"
SMTP_USER="your_email@gmail.com"
SMTP_PASSWORD="your_app_password"
SMTP_FROM="your_email@gmail.com"

# Configuración de URL del frontend
FRONTEND_URL="http://localhost:3000"

# ======================================
# OAuth 2.0 Partner Integration (Malet)
# ======================================
# Nota: Estos valores se generan dinámicamente al crear un cliente OAuth.
# Aquí solo se documentan como referencia.

# OAuth Client ID for Malet (auto-generated when creating OAuth client)
# MALET_CLIENT_ID="client_xxxxxxxxxxxxx"

# OAuth Client Secret (auto-generated, keep secure)
# MALET_CLIENT_SECRET="secret_xxxxxxxxxxxxx"

# Allowed redirect URIs (comma-separated)
MALET_ALLOWED_REDIRECT_URIS="malet://integrations/callback,https://api.malet.com/integrations/wheek/callback"

# Partner API Key for provisioning (auto-generated when creating partner)
# MALET_PARTNER_API_KEY="partner_key_xxxxxxxxxxxxx"

# Enable user provisioning for this partner
MALET_ALLOWED_PROVISIONING="true"

# Partner display name
MALET_PARTNER_NAME="Malet App"